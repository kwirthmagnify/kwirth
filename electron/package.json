{
	"name": "kwirth-magnify",
	"author": {
		"name": "Julio Fernandez",
		"email": "jfvilas@outlook.com",
		"url": "https://github.com/jfvilas"
	},
	"main": "main.js",
	"version": "0.5.21",
	"description": "Kwirth magnify is a desktop software for managing your Kubernetes clusters. It is based on Kwirth OSS, that can be deployed to your Desktop, as an external server or directly inside your Kubernetes cluster as a Pod",
	"homepage": "https://kwirthmagnify.github.io/kwirth",
	"scripts": {
		"start": "electron .",
		"dist": "electron-builder",
		"dist:win": "electron-builder --win",
    	"dist:linux": "electron-builder --linux",
    	"dist:mac": "electron-builder --mac"
	},
	"build": {
		"appId": "com.github.kwirth",
		"files": [
			"./main.js",
			"./preload.js",
			"./splash.png",
			"./version.js",
			"./bundle/**/*"
		],
		"asar": false,
		"directories": {
			"output": "dist" 
		},
		"win": {
			"icon": "kwirth-last.ico",
			"target": [
				{
					"target": "nsis", 
					"arch": ["x64"]
				},
				{
					"target": "portable", 
					"arch": ["x64"]
				}
			]
		},
		"linux": {
			"icon": "kwirth-last.png",
			"target": ["AppImage"], 
			"category": "Utility",
			"executableArgs": ["--no-sandbox"]
		},
		"mac": {
			"target": ["dmg", "zip"],
			"category": "public.app-category.utilities"
		}
	},
	"dependencies": {
		"portfinder": "^1.0.38"
	},
	"devDependencies": {
		"concurrently": "^9.2.1",
		"electron": "^40.1.0",
		"electron-builder": "^26.4.0",
		"wait-on": "^9.0.3"
	}
}
