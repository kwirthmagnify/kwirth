{
  "name": "kwirth-back",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && esbuild dist/index.js --bundle --platform=node --target=node24 --outfile=bundle/bundle.js --external:cpu-features",
    "not-used-start": "cross-env NODE_OPTIONS=\"--expose-gc --max-old-space-size=1024 --trace-warnings --unhandled-rejections=strict\" nodemon src/index.ts",
    "start:kubernetes": "cross-env NODE_OPTIONS=\"--expose-gc --max-old-space-size=1024 --trace-warnings --unhandled-rejections=strict\" FORCE=k8s nodemon src/index.ts",
    "start:docker": "cross-env NODE_OPTIONS=\"--expose-gc --max-old-space-size=1024 --trace-warnings --unhandled-rejections=strict\" FORCE=docker nodemon src/index.ts",
    "start:electron": "cross-env NODE_OPTIONS=\"--expose-gc --max-old-space-size=1024 --trace-warnings --unhandled-rejections=strict\" FORCE=electron AUTH=kubeconfig nodemon src/index.ts"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/groq": "^3.0.35",
    "@ai-sdk/mistral": "^3.0.30",
    "@ai-sdk/openai": "^3.0.53",
    "@jfvilas/parse-listing": "^1.0.1",
    "@kubernetes/client-node": "^1.4.0",
    "@kwirthmagnify/kwirth-common": "^0.4.51",
    "@openrouter/ai-sdk-provider": "^2.8.0",
    "@types/node": "^20.12.13",
    "ai": "^6.0.168",
    "body-parser": "^1.20.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dockerode": "^4.0.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-fileupload": "^1.5.2",
    "http-proxy-middleware": "^3.0.5",
    "request-ip": "^3.3.0",
    "ts-semaphore": "^1.0.0",
    "uuid": "^11.1.0",
    "ws": "^8.17.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/dockerode": "^3.3.37",
    "@types/express": "^4.17.21",
    "@types/express-fileupload": "^1.5.1",
    "@types/node-fetch": "^2.6.11",
    "@types/ws": "^8.5.10",
    "cross-env": "^10.1.0",
