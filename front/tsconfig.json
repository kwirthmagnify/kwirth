{
  "compilerOptions": {
    "target": "es2015",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module":"CommonJS",
    "isolatedModules": true,
    "jsx": "react-jsx",
    "moduleResolution": "node16"
  },
  "include": [
    "src",
    "src/*.d.ts"
  ]
}
